# Copy this file to .env for local development:
#   cp .env.example .env
#
# Local development uses a SQLite file. Prisma reads DATABASE_URL from .env.
DATABASE_URL="file:./dev.db"

# --- Production (Vercel + Turso) — leave these unset locally ---
# When TURSO_DATABASE_URL is set, the app talks to Turso via the libSQL adapter
# (src/lib/db.ts) instead of the local SQLite file. Set these in Vercel, not here.
# TURSO_DATABASE_URL="libsql://seo-dashboard-<org>.turso.io"
# TURSO_AUTH_TOKEN="<token from: turso db tokens create seo-dashboard>"

# Secret that protects the daily /api/cron/audit route (Vercel sends it as a
# Bearer token). Any long random string.
# CRON_SECRET="<random-string>"

# Set to 1 to make audits crawl live URLs with Playwright instead of using the
# built-in synthetic snapshots. Needs a Chromium-capable host (not serverless).
# LIVE_AUDITS=1
